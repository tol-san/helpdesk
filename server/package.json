{
    "name": "helpdesk-server",
    "version": "1.0.0",
    "description": "Express.js backend with TypeScript",
    "main": "dist/index.js",
    "type": "module",
    "scripts": {
        "dev": "bun run --hot src/index.ts",
        "build": "bun build ./src/index.ts --outdir ./dist --target node",
        "start": "node dist/index.js",
        "type-check": "bun tsc --noEmit"
    },
    "dependencies": {
        "express": "^5.0.0",
        "cors": "^2.8.5",
        "dotenv": "^16.0.3"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "@types/express": "^4.17.21",
        "@types/cors": "^2.8.17",
        "@types/node": "^20.10.0",
        "typescript": "^5.3.3"
    }
}